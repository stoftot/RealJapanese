@inherits ToggleSliderBase

<div class="toggle-slider @CssClass" role="group" aria-label="Toggle selection">
    <div class="toggle-slider-track">
        @foreach (var option in Options)
        {
            <button type="button"
                    class="toggle-slider-option @(option.Index == CurrentIndex ? "active" : "")"
                    aria-pressed="@(option.Index == CurrentIndex)"
                    @key="option.Index"
                    @onclick="@(() => OnOptionClicked(option.Index))">
                @option.Text
            </button>
        }
    </div>
</div>
