@inherits FlashPracticeCardBase
@namespace RealJapanese.Components.Shared

<div class="d-flex justify-content-center">
    <div class="practice-wrap w-100">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title mb-0">@Title</h5>
                        <small class="text-muted">@ProgressText</small>
                    </div>

                    <p class="lead mb-3" style="white-space: pre-line; text-align: center; font-size: xx-large">@Question</p>

                    @if (ShowAnswer && !string.IsNullOrEmpty(Answer))
                    {
                        <div class="alert alert-info mt-3" role="alert">
                            <strong>Answer:</strong> @Answer
                        </div>
                    }

                    <div class="d-flex justify-content-center mt-4">
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="TriggerPrimaryActionAsync"
                                @ref="actionButtonRef">
                            @PrimaryActionLabel
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
