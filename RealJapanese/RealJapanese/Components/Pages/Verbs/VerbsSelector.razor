@page "/verbs"
@using DataLoaders.Models
@using RealJapanese.Components.Shared
@inherits VerbSelectorBase
@rendermode InteractiveServer

<div class="container my-3">
    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <WordList
                TItem="Verb"
                Title="Known vocabulary"
                AllWords="@AllWords"
                SelectedIds="@KnownIds"
                WordSelected="@OnKnownWordSelected"
                WordDeselected="@OnKnownWordDeSelected"
            />
        </div>

        <div class="col-md-6 col-lg-4">
            <WordList
                TItem="Verb"
                Title="Currently rehearsing"
                AllWords="@AllWords.Where(w => !KnownIds.Contains(w.Id)).ToList()"
                SelectedIds="@RehearsingIds"
                WordSelected="@OnRehearsingWordSelected"
                WordDeselected="@OnRehearsingWordDeSelected"
            />
        </div>

        <div class="col-md-6 col-lg-4">
            <WordList
                TItem="Verb"
                Title="Currently training"
                AllWords="@AllWords.Where(w => !KnownIds.Contains(w.Id) && 
                                               !RehearsingIds.Contains(w.Id)).ToList()"
                SelectedIds="@TrainingIds"
                WordSelected="@OnTrainingWordSelected"
                WordDeselected="@OnTrainingWordDeSelected"
            />
        </div>
    </div>
</div>

<ToggleSlider LeftText="Known"
              MiddleText="Rehearsing"
              RightText="Training"
              @bind-SelectedIndex="SelectedCategoryIndex"
/>

<PraticeSelector
    MainUrl="verbs"
    Pages="@(new List<PraticeSelectorBase.PageDescreption>
           {
               new()
               {
                   Title = "Learn the verbs",
                   Description = "Practice the spelling of the verbs",
                   Url = $"spelling?category={SelectedCategoryQueryValue}"
               },
               
               new()
               {
                   Title = "Verb type categorisation",
                   Description = "Practice categorising the different Verb, into u-, ru- and irregular-verbs",
                   Url = $"categories?category={SelectedCategoryQueryValue}"
               },
               new()
               {
                   Title = "Verb Conjugation and forms - stem",
                   Description = "Practice different conjugations and forms on stems(not real verbs)",
                   Url = "ConjugationsAndForms"
               },

               new()
               {
                   Title = "Verb Conjugation",
                   Description = "Practice verb conjugations",
                   Url = "conjugation"
               },

               new()
               {
                   Title = "Fill in the verb",
                   Description = "Practice filling in the correct verbs",
                   Url = "fillIn"
               }
           })"
/>
